{
  "name": "pi-printer-tools",
  "version": "0.1.0",
  "type": "module",
  "description": "codegraph (tree-sitter code navigation/patching) and computer (desktop control) as first-class pi tools, with token-saving search integration",
  "keywords": [
    "pi-package",
    "codegraph",
    "computer",
    "code-search"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sarocu/printer",
    "directory": "plugins/pi"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.79.1",
    "@earendil-works/pi-coding-agent": "^0.79.1",
    "@types/node": "^22.0.0",
    "typebox": "^1.2.8",
    "typescript": "^5.6.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  }
}
